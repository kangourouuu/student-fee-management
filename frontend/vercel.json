{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist/student-fee-frontend/browser",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://student-fee-backend-nopb.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
